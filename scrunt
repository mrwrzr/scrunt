#!/bin/bash
# scrunt - Simple Coordinated Regular Update Nexus Tool
# mrwrzr 2026 (MIT License)
# "I'm gonna scrunt"

set -e

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/scrunt"
CONFIG_FILE="$CONFIG_DIR/config"
HOOKS_DIR="$CONFIG_DIR/hooks"
PRE_HOOKS_DIR="$HOOKS_DIR/pre"
POST_HOOKS_DIR="$HOOKS_DIR/post"

# argument defaults:
LOOK_MODE=false
FORCE_TOGGLE=false
EDIT_CONFIG=false

while [[ $# -gt 0 ]]; do
    case $1 in
        --huh) LOOK_MODE=true; shift ;;
        --tog) FORCE_TOGGLE=true; shift ;;
        --config) EDIT_CONFIG=true; shift ;;
        *) shift ;;
    esac
done

if [ "$EDIT_CONFIG" = true ]; then
    if [ -f "$CONFIG_FILE" ]; then
        ${EDITOR:-nano} "$CONFIG_FILE"
    else
        echo "( !ERROR! ) No config found - run scrunt-wizard"
        exit 1
    fi
    exit 0
fi

if [ ! -f "$CONFIG_FILE" ]; then
    echo "( ! ) ~/.config/scrunt not found - running setup"
    scrunt-wizard
    exit 0
fi

source "$CONFIG_FILE"

if [ -z "$PM" ]; then
    echo "( !ERROR! ) No package manager configuration was found. Try running scrunt-wizard"
    exit 1
fi

if [ "$FORCE_TOGGLE" = true ]; then
    if [ "$CONFIRM_UPDATE" = true ]; then
        USE_APPROVE=false
    else
        USE_APPROVE=true
    fi
else
    USE_APPROVE="$CONFIRM_UPDATE"
fi

sudo -v 2>/dev/null || true

if [ "$PM" = "pacman" ] && [ -z "$AUR_HELPER" ]; then
    if command -v paru &>/dev/null; then
        echo "Found paru! Enable? (y/N)"
        read -rp "> " enable_aur
        if [[ "$enable_aur" =~ ^[Yy]$ ]]; then
            AUR_HELPER="paru"
            sed -i "s/^AUR_HELPER=.*/AUR_HELPER=\"paru\"/" "$CONFIG_FILE"
        fi
    elif command -v yay &>/dev/null; then
        echo "Found yay! Enable? (y/N)"
        read -rp "> " enable_aur
        if [[ "$enable_aur" =~ ^[Yy]$ ]]; then
            AUR_HELPER="yay"
            sed -i "s/^AUR_HELPER=.*/AUR_HELPER=\"yay\"/" "$CONFIG_FILE"
        fi
    fi
fi

if [ "$USE_APPROVE" = false ]; then
    PACMAN_APPROVE="--noconfirm"
    APT_APPROVE="-y"
    DNF_APPROVE="-y"
    YUM_APPROVE="-y"
    ZYPPER_APPROVE="--non-interactive"
    FLATPAK_APPROVE="-y"
    SNAP_APPROVE=""
else
    PACMAN_APPROVE=""
    APT_APPROVE=""
    DNF_APPROVE=""
    YUM_APPROVE=""
    ZYPPER_APPROVE=""
    FLATPAK_APPROVE=""
    SNAP_APPROVE=""
fi

sudo -v 2>/dev/null || true

if [ "$SAVE_PACKAGE_LIST" = true ] && [ "$LOOK_MODE" = false ]; then
    case $PM in
        pacman)
            pacman -Qqen > "$CONFIG_DIR/pkglist.txt"
            ;;
        apt)
            apt list --installed 2>/dev/null | cut -d/ -f1 > "$CONFIG_DIR/pkglist.txt"
            ;;
        dnf|yum)
            rpm -qa | sort > "$CONFIG_DIR/pkglist.txt"
            ;;
        zypper)
            zypper se --installed-only | tail -n +5 | awk '{print $3}' > "$CONFIG_DIR/pkglist.txt"
            ;;
    esac
fi

if [ "$CREATE_SNAPSHOT" = true ] && [ "$LOOK_MODE" = false ]; then
    if command -v timeshift &>/dev/null; then
        sudo timeshift --create --comments "Pre-update snapshot by scrunt"
    elif command -v snapper &>/dev/null; then
        sudo snapper create --description "Pre-update snapshot by scrunt"
    fi
fi

if [ -d "$PRE_HOOKS_DIR" ]; then
    for hook in "$PRE_HOOKS_DIR"/*.sh; do
        [ -f "$hook" ] || continue
        bash "$hook"
    done
fi

case $PM in
    pacman)
        if [ "$LOOK_MODE" = true ]; then
            sudo pacman -Syu --print
            if [ -n "$AUR_HELPER" ] && command -v "$AUR_HELPER" &>/dev/null; then
                $AUR_HELPER -Syu --print
            fi
        else
            PACMAN_OUT=$(sudo pacman -Syu $PACMAN_APPROVE)
            if [ -n "$AUR_HELPER" ] && command -v "$AUR_HELPER" &>/dev/null; then
                AUR_OUT=$($AUR_HELPER -Syu $PACMAN_APPROVE)
            fi
        fi
        ;;
    apt)
        if [ "$LOOK_MODE" = true ]; then
            sudo apt update >/dev/null 2>&1
            apt list --upgradable 2>/dev/null
        else
            sudo apt update >/dev/null 2>&1
            APT_OUT=$(sudo apt upgrade $APT_APPROVE)
        fi
        ;;
    dnf)
        if [ "$LOOK_MODE" = true ]; then
            sudo dnf check-update
        else
            DNF_OUT=$(sudo dnf upgrade $DNF_APPROVE)
        fi
        ;;
    yum)
        if [ "$LOOK_MODE" = true ]; then
            sudo yum check-update || true
        else
            YUM_OUT=$(sudo yum update $YUM_APPROVE)
        fi
        ;;
    zypper)
        if [ "$LOOK_MODE" = true ]; then
            sudo zypper refresh --dry-run
            sudo zypper list-updates
        else
            sudo zypper refresh >/dev/null 2>&1
            ZYPPER_OUT=$(sudo zypper update $ZYPPER_APPROVE)
        fi
        ;;
    *)
        echo "( !ERROR! ) Unsupported package manager '$PM' :("
        exit 1
        ;;
esac

if [ "$FLATPAK" = true ] && command -v flatpak &>/dev/null; then
    if [ "$LOOK_MODE" = true ]; then
        flatpak update --dry-run
    else
        FLATPAK_OUT=$(flatpak update $FLATPAK_APPROVE)
    fi
fi

if [ "$SNAP" = true ] && command -v snap &>/dev/null; then
    if [ "$LOOK_MODE" = true ]; then
        snap refresh --list
    else
        SNAP_OUT=$(snap refresh)
    fi
fi

if [ "$LOOK_MODE" = true ]; then
    exit 0
fi

if [ -d "$POST_HOOKS_DIR" ]; then
    for hook in "$POST_HOOKS_DIR"/*.sh; do
        [ -f "$hook" ] || continue
        package=$(basename "$hook" .sh)

        case $PM in
            pacman)
                if echo "${PACMAN_OUT:-} ${AUR_OUT:-}" | grep -qiE "(upgrading|installing).*${package}"; then
                    bash "$hook"
                fi
                ;;
            apt)
                if echo "${APT_OUT:-}" | grep -qiE "Unpacking ${package}"; then
                    bash "$hook"
                fi
                ;;
            dnf|yum)
                if echo "${DNF_OUT:-} ${YUM_OUT:-}" | grep -qiE "Upgrading: ${package}"; then
                    bash "$hook"
                fi
                ;;
            zypper)
                if echo "${ZYPPER_OUT:-}" | grep -qiE "upgrading ${package}"; then
                    bash "$hook"
                fi
                ;;
        esac
    done
fi

if [ "$FLATPAK" = true ] && [ -n "$FLATPAK_OUT" ] && [ -d "$POST_HOOKS_DIR" ]; then
    for hook in "$POST_HOOKS_DIR"/*.sh; do
        [ -f "$hook" ] || continue
        package=$(basename "$hook" .sh)
        if echo "$FLATPAK_OUT" | grep -qiE "$package"; then
            bash "$hook"
        fi
    done
fi

if [ "$SNAP" = true ] && [ -n "$SNAP_OUT" ] && [ -d "$POST_HOOKS_DIR" ]; then
    for hook in "$POST_HOOKS_DIR"/*.sh; do
        [ -f "$hook" ] || continue
        package=$(basename "$hook" .sh)
        if echo "$SNAP_OUT" | grep -qiE "$package"; then
            bash "$hook"
        fi
    done
fi

if [ "$FASTFETCH" = true ] && command -v fastfetch &>/dev/null; then
    fastfetch
fi
